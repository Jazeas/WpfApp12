<Window x:Class="WpfApp12.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Students" Height="450" Width="750">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <ListView x:Name="studentList"
                  ItemsSource="{Binding Students}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Имя"
                                    DisplayMemberBinding="{Binding FirstName}" />
                    <GridViewColumn Header="Фамилия"
                                    DisplayMemberBinding="{Binding LastName}" />
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Column="1" Margin="10">

            <TextBlock Text="Имя"/>
            <TextBox Text="{Binding SelectedItem.FirstName,
                            ElementName=studentList,
                            UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Text="Фамилия"/>
            <TextBox Text="{Binding SelectedItem.LastName,
                            ElementName=studentList,
                            UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Text="Возраст"/>
            <TextBox Text="{Binding SelectedItem.Age,
                            ElementName=studentList,
                            UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Text="Группа"/>
            <TextBox Text="{Binding SelectedItem.Group,
                            ElementName=studentList,
                            UpdateSourceTrigger=PropertyChanged}" />

            <Button Content="Удалить"
                    Margin="0,10,0,10"
                    Click="Delete_Click"/>

            <TextBlock Text="Добавить студента"/>
            
            <TextBlock Text="Имя" />
            <TextBox x:Name="newFirstName"/>
            
            <TextBlock Text="Фамилия"/>
            <TextBox x:Name="newLastName"/>
            
            <TextBlock Text="Возраст"/>
            <TextBox x:Name="newAge"/>
            
            <TextBlock Text="Группа"/>
            <TextBox x:Name="newGroup"/>

            <Button Content="Добавить"
                    Click="Add_Click"/>
        </StackPanel>

    </Grid>
</Window>